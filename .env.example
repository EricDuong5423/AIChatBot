# ── LLM Backend ─────────────────────────────────────────────────────────────
# Ollama local (mặc định, không cần key):
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:7b
# LLM_API_KEY=

# Groq cloud (miễn phí, nhanh hơn — đăng ký tại console.groq.com):
OLLAMA_BASE_URL=https://api.groq.com/openai/v1
OLLAMA_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=your_groq_api_key_here

# MongoDB
MONGODB_URI=mongodb://user:password@host:27017/
MONGODB_DB_NAME=hcmut_chatbot

# Bảo mật: API key để C# backend xác thực khi gọi vào chatbot service
# Để trống = không cần key (chỉ dùng trong dev)
CHATBOT_API_KEY=your_secret_key_here

# CORS: danh sách origin của C# backend, cách nhau bằng dấu phẩy
CHATBOT_ALLOWED_ORIGINS=http://localhost:5123,http://localhost:7178
